<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About | PitchWear</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg: "#fbfaf7",
            borderTone: "#d9d6c8",
            card: "#f3f1e7",
            primaryBtn: "#b36a8d",
            primaryBtnHover: "#9b5576",
          }
        }
      }
    }
  </script>
</head>

<body class="bg-bg text-gray-800">

<!-- HEADER -->
<header class="w-full bg-bg border-b border-borderTone">
  <div class="max-w-6xl mx-auto px-4 py-5 flex justify-between items-center">

    <a href="/home" class="font-bold text-lg tracking-wide">PitchWear</a>

    <nav class="hidden md:flex gap-10 text-sm">
      <a href="/home" class="hover:underline">Home</a>
      <a href="/shop" class="hover:underline">Shop</a>
      <a href="/about" class="hover:underline font-medium">About</a>
    </nav>

  </div>
</header>

<main class="max-w-6xl mx-auto px-4 py-12">

  <!-- HERO -->
  <section class="text-center py-16">
    <h1 class="text-4xl md:text-5xl font-semibold mb-4">
      About PitchWear
    </h1>
    <p class="text-gray-500 max-w-xl mx-auto">
      Where football passion meets everyday fashion.
    </p>
  </section>

  <!-- IMAGE + STORY -->
  <section class="grid md:grid-cols-2 gap-10 items-center">

    <img 
      src="https://images.unsplash.com/photo-1517927033932-b3d18e61fb3a"
      class="rounded-xl shadow-md object-cover w-full h-[320px]"
    />

    <div>
      <h2 class="text-2xl font-semibold mb-4">Our Story</h2>

      <p class="text-gray-600 leading-relaxed">
        PitchWear was built for fans who live and breathe football. 
        We aim to deliver high-quality jerseys that combine comfort, style, 
        and authenticity — all at accessible prices.
      </p>

      <p class="mt-4 text-gray-600">
        From browsing to checkout, every part of the experience is designed 
        to be simple, fast, and reliable.
      </p>
    </div>

  </section>

  <!-- FEATURES -->
  <section class="mt-16 grid md:grid-cols-4 gap-6 text-center">

    <div class="p-6 bg-card rounded-xl border border-borderTone hover:shadow transition">
      🚚
      <h4 class="mt-2 font-medium">Fast Delivery</h4>
      <p class="text-sm text-gray-500 mt-1">Quick & reliable shipping</p>
    </div>

    <div class="p-6 bg-card rounded-xl border border-borderTone hover:shadow transition">
      💳
      <h4 class="mt-2 font-medium">Secure Payments</h4>
      <p class="text-sm text-gray-500 mt-1">Safe & trusted checkout</p>
    </div>

    <div class="p-6 bg-card rounded-xl border border-borderTone hover:shadow transition">
      🔄
      <h4 class="mt-2 font-medium">Easy Returns</h4>
      <p class="text-sm text-gray-500 mt-1">Hassle-free returns</p>
    </div>

    <div class="p-6 bg-card rounded-xl border border-borderTone hover:shadow transition">
      ⭐
      <h4 class="mt-2 font-medium">Top Quality</h4>
      <p class="text-sm text-gray-500 mt-1">Premium materials</p>
    </div>

  </section>

  <!-- CTA -->
  <section class="mt-20 text-center bg-black text-white py-14 rounded-xl">
    <h2 class="text-2xl font-semibold">Explore Our Collection</h2>

    <a href="/shop"
       class="inline-block mt-6 px-6 py-3 bg-white text-black rounded-lg font-medium hover:bg-gray-200 transition">
       Shop Now
    </a>
  </section>

</main>

<!-- FOOTER -->
<footer class="mt-16 border-t border-borderTone py-6 text-center text-sm text-gray-500">
  © 2026 PitchWear. All rights reserved.
</footer>

</body>
</html>
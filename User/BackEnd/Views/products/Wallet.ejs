<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Wallet | PitchWear</title>

<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
theme: {
extend: {
colors: {
primary: '#7da77b',
bgLight: '#faf9f6'
}
}
}
}
</script>

</head>

<body class="bg-bgLight text-gray-800">

<!-- HEADER -->
<header class="bg-[#f5f6df] px-16 py-4 flex justify-between items-center">
<h1 class="text-lg font-semibold">PitchWear</h1>

<nav class="flex items-center gap-10 text-sm">
<a href="/Home" class="hover:text-primary">Home</a>
<a href="/shop" class="hover:text-primary">Shop</a>
<a href="#" class="hover:text-primary">About</a>
<a href="#" class="hover:text-primary">Contact</a>

<% if (user.profileImage) { %>
<img src="<%= user.profileImage %>"
class="w-8 h-8 rounded-full object-cover border">
<% } else { %>
<div
class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-semibold"
style="background-color:#1e3a8a">
<%= user.fullName.charAt(0).toUpperCase() %>
</div>
<% } %>

</nav>
</header>

<!-- MAIN -->
<main class="px-16 py-14 flex gap-16">

<!-- SIDEBAR -->
<aside class="w-64">

<div class="bg-white rounded-lg p-4 mb-6">
<p class="text-sm font-medium">My Account</p>
<p class="text-xs text-gray-500"><%= user.fullName %></p>
</div>

<ul class="space-y-4 text-sm">

<li>
<a href="/orders" class="hover:text-primary">My Orders</a>
</li>

<li>
<a href="/address" class="hover:text-primary">Address Book</a>
</li>

<li>
<a href="/wallet" class="text-primary font-medium">Wallet</a>
</li>

</ul>

<div class="mt-10 text-sm space-y-4">
<p>About Us</p>
<p>Contact Us</p>
<a href="/logout" class="text-red-500">← Logout</a>
</div>

</aside>


<!-- WALLET CONTENT -->
<section class="flex-1 bg-white rounded-xl p-10">

<h2 class="text-2xl font-semibold mb-8">My Wallet</h2>

<!-- BALANCE CARD -->
<div class="bg-[#f8f8f4] p-6 rounded-lg mb-10">

<p class="text-gray-500 text-sm">Available Balance</p>

<p class="text-4xl font-bold text-green-600 mt-2">
₹<%= wallet.balance.toFixed(2) %>
</p>

</div>


<!-- TRANSACTIONS -->
<h3 class="text-lg font-semibold mb-4">Transaction History</h3>

<table class="w-full text-sm">

<thead class="border-b">
<tr>
<th class="py-3 text-left">Date</th>
<th class="text-left">Type</th>
<th class="text-left">Amount</th>
<th class="text-left">Description</th>
</tr>
</thead>

<tbody>

<% wallet.transactions.slice().reverse().forEach(txn => { %>

<tr class="border-b">

<td class="py-3">
<%= new Date(txn.createdAt).toLocaleDateString() %>
</td>

<td>
<span class="<%= txn.type === 'Credit' ? 'text-green-600' : 'text-red-500' %>">
<%= txn.type %>
</span>
</td>

<td>
₹<%= txn.amount %>
</td>

<td>
<%= txn.description %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</section>

</main>

</body>
</html>
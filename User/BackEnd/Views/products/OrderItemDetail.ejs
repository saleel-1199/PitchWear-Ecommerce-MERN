<!DOCTYPE html>
<html>
<head>
  <title>Order Details | PitchWear</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>


<body class="bg-[#f8f8f4] text-gray-800">

<header class="bg-[#eff2c8] px-10 py-5 flex justify-between items-center">
  <h1 class="font-bold text-lg">PitchWear</h1>
  <nav class="flex gap-8 text-sm">
    <a href="/">Home</a>
    <a href="/shop">Shop</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
  </nav>

  <div class="flex gap-4 text-lg">

    <!-- CART -->
    <a href="/cart" title="Cart">🛒</a>

    <!-- PROFILE -->
    <a href="/profile" title="Profile">👤</a>

  </div>


</header>

<div class="px-10 mt-3">
  <a href="/orders"
     class="inline-flex items-center gap-2 bg-gray-200 px-4 py-2 rounded-lg text-sm hover:bg-gray-300 transition">
     ←  
  </a>
</div>


<main class="max-w-5xl mx-auto py-12">

  <h2 class="text-2xl font-semibold mb-4">Order Details</h2>

  <p class="text-xs text-pink-600 mb-2">
    Order Date: <%= new Date(order.createdAt).toDateString() %>
  </p>
        


  <p class="font-semibold mb-10">
    Order ID: #<%= order.orderId %>
  </p>

  <p class="text-sm mb-2">
  Payment: 
  <span class="<%= order.paymentStatus === 'Failed' ? 'text-red-600' : 'text-green-600' %>">
    <%= order.paymentStatus %>
  </span>
</p>
  

  <p class="font-semibold mb-10">
  Order ID: #<%= order.orderId %>
</p>

<% if(order.paymentMethod === "Razorpay" && order.paymentStatus === "Failed") { %>
  <button 
  id="retryBtn"
  onclick="retryPayment('<%= order._id %>')"
  class="bg-red-500 text-white px-5 py-2 rounded-lg text-sm">
  Retry Payment
</button>
<% } %>



  <!-- LOOP ALL ITEMS -->
  <% order.items.forEach(item => { %>

  <div class="border rounded-xl p-6 mb-10 bg-white">

    <!-- ITEM STATUS -->
    <p class="text-sm mb-2 font-medium"><%= item.status %></p>

    <!-- PROGRESS BAR -->
    <div class="w-full h-2 bg-pink-200 rounded-full mb-6">
      <div class="h-2 bg-pink-500 rounded-full"
           style="width: <%= item.status === 'Pending' ? '25%' :
                             item.status === 'Shipped' ? '50%' :
                             item.status === 'Out for Delivery' ? '75%' :
                             item.status === 'Delivered' ? '100%' :
                             item.status === 'Cancelled' ? '100%' :
                             item.status === 'Returned' ? '100%' : '0%' %>">
      </div>
    </div>

    <div class="flex justify-between items-center">

      <div>
        <h3 class="font-semibold mb-2 text-lg">
          <%= item.product?.name %>
        </h3>

        <p class="text-sm text-gray-600">
          Team: <%= item.product?.team?.name %> |
          Size: <%= item.size %> |
          Qty: <%= item.quantity %>
        </p>

        <p class="text-sm mt-3 font-medium text-pink-600">
          ₹<%= (item.price * item.quantity).toFixed(2) %>
        </p>
      </div>

      <div>
        <img src="<%= item.product?.images?.[0] || '/images/no-image.png' %>"
             class="w-40 object-contain"/>
      </div>

    </div>

    <!-- ACTION BUTTONS -->
<div class="flex gap-4 mt-6">


 

 
  <% if (order.status === "Delivered" || order.status === "Partially Completed" ) { %>

    <button onclick="openReturnModal('<%= order._id %>','<%= item._id %>')"
            class="bg-yellow-600 text-white px-5 py-2 rounded-lg text-sm hover:bg-yellow-700">
        Return
    </button>

  <% } %>

 
  <% if (order.status !== "Delivered" && item.status !== "Cancelled" && item.status !== "Returned") { %>

    <button onclick="openCancelModal('<%= order._id %>','<%= item._id %>')"
            class="bg-red-600 text-white px-5 py-2 rounded-lg text-sm hover:bg-red-700">
        Cancel
    </button>

  <% } %>

</div>

  </div>

  <% }) %>

  <div class="flex justify-end mb-10">

  <a href="/orders/<%= order._id %>/invoice"
     class="bg-black text-white px-6 py-3 rounded-lg text-sm hover:bg-gray-800 transition">
     📄 Download Invoice
  </a>

</div>

  <!-- DELIVERY ADDRESS -->
  <h3 class="font-semibold mb-2">Delivery Address</h3>
  <p class="text-sm mb-10">
    <%= order.addressSnapshot.fullName %><br>
    <%= order.addressSnapshot.addressLine %><br>
    <%= order.addressSnapshot.city %>,
    <%= order.addressSnapshot.state %>
    <%= order.addressSnapshot.pincode %>
  </p>

  <!-- PRICE SUMMARY -->
  <h3 class="font-semibold mb-4">Price Summary</h3>

  <div class="text-sm space-y-2 max-w-md mb-8">
    <div class="flex justify-between">
      <span class="text-pink-600">Subtotal</span>
      <span>₹<%= order.subtotal.toFixed(2) %></span>
    </div>

    <div class="flex justify-between">
      <span class="text-pink-600">Shipping</span>
      <span>₹<%= order.deliveryFee.toFixed(2) %></span>
    </div>

    <div class="flex justify-between">
      <span class="text-pink-600">Tax</span>
      <span>₹<%= order.tax.toFixed(2) %></span>
    </div>

    <div class="flex justify-between font-semibold border-t pt-2">
      <span class="text-pink-600">Total</span>
      <span>₹<%= order.finalTotal.toFixed(2) %></span>
    </div>
  </div>

</main>


<!-- CANCEL MODAL -->
<div id="cancelModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center">
  <div class="bg-white p-6 rounded-lg w-96">
    <h3 class="font-semibold text-lg mb-4">Cancel Item</h3>
    <p class="text-sm mb-4">Are you sure you want to cancel this item?</p>

    <form id="cancelForm" method="POST">
      <div class="flex justify-end gap-3">
        <button type="button" onclick="closeCancelModal()"
                class="bg-gray-300 px-4 py-2 rounded">
          No
        </button>
        <button type="submit"
                class="bg-red-600 text-white px-4 py-2 rounded">
          Yes, Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<!-- RETURN MODAL -->
<div id="returnModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center">
  <div class="bg-white p-6 rounded-lg w-96">
    <h3 class="font-semibold text-lg mb-4">Return Item</h3>

    <form id="returnForm" method="POST">
  <textarea
    name="reason"
    required
    placeholder="Enter return reason..."
    class="w-full border p-2 rounded mb-4"
  ></textarea>

      <div class="flex justify-end gap-3">
        <button type="button" onclick="closeReturnModal()"
                class="bg-gray-300 px-4 py-2 rounded">
          Cancel
        </button>
        <button type="submit"
                class="bg-yellow-600 text-white px-4 py-2 rounded">
          Submit Return
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function openCancelModal(orderId, itemId) {
  const form = document.getElementById("cancelForm");
  form.action = `/orders/${orderId}/item/${itemId}/cancel`;
  document.getElementById("cancelModal").classList.remove("hidden");
}

function closeCancelModal() {
  document.getElementById("cancelModal").classList.add("hidden");
}

function openReturnModal(orderId, itemId) {
  const form = document.getElementById("returnForm");
  form.action = `/orders/${orderId}/item/${itemId}/return`;
  document.getElementById("returnModal").classList.remove("hidden");
}

function closeReturnModal() {
  document.getElementById("returnModal").classList.add("hidden");
}
</script>


<script src="https://checkout.razorpay.com/v1/checkout.js"></script>



<script>
async function retryPayment(orderId){

  const btn = document.getElementById("retryBtn");
  btn.disabled = true;
  btn.innerText = "Processing...";

  let data;

  try {
    const res = await fetch(`/retry-payment/${orderId}`, {
      method: "POST"
    });

    data = await res.json();
  } catch (err) {
    showAlertModal("Network error");

    // 🔥 re-enable button if error
    btn.disabled = false;
    btn.innerText = "Retry Payment";

    return;
  }
 

  if(!data.success){
    showAlertModal(data.message || "Something went wrong");
    return;
  }

  const options = {
    key: data.key,
    amount: data.razorpayOrder.amount,
    currency: "INR",
    order_id: data.razorpayOrder.id,

    handler: async function(response){

  if(!response.razorpay_payment_id){
    
    // 🔥 TREAT AS FAILURE
    await fetch("/payment-failed", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        orderId: response.razorpay_order_id
      })
    });

    window.location.href =
      "/orders/" + data.order._id + "?payment=failed";

    return;
  }

  // ✅ SUCCESS FLOW
  await fetch("/verify-payment",{
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({
      orderId:response.razorpay_order_id,
      paymentId:response.razorpay_payment_id
    })
  });

  window.location.href="/order-success/"+data.order._id;
}
  };

  const rzp = new Razorpay(options);
  rzp.open();

  rzp.on("payment.failed", function () {
    showAlertModal("Payment failed again");
    window.location.href = "/orders";
  });
}
</script>



<script>
document.getElementById("cancelForm")
.addEventListener("submit", function () {

  // small delay to allow backend redirect
  setTimeout(() => {
    window.location.reload();
  }, 200);

});
</script>



<script>
let redirectAfterClose = null;

function showAlertModal(message, redirect = null) {
  document.getElementById("modalMessage").innerText = message;

  const modal = document.getElementById("customModal");
  modal.classList.remove("hidden");
  modal.classList.add("flex");

  redirectAfterClose = redirect;
}

function closeAlertModal() {
  const modal = document.getElementById("customModal");

  modal.classList.add("hidden");
  modal.classList.remove("flex");

  if (redirectAfterClose) {
    window.location.href = redirectAfterClose;
  }
}
</script>

<script>
window.addEventListener("DOMContentLoaded", () => {

   const paymentFailed = <%= JSON.stringify(paymentFailed || false) %>;
 
   if (paymentFailed) {
    showAlertModal(
      "❌ Last payment failed. You can retry payment."
    );

    // 🔥 optional: scroll to retry button
    document.getElementById("retryBtn")?.scrollIntoView({
      behavior: "smooth",
      block: "center"
    });
  }

});
</script>

<!-- GLOBAL ALERT MODAL (NEW) -->
<div id="customModal" class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50">

  <div class="bg-white rounded-xl shadow-lg w-[350px] p-6 text-center">

    <p id="modalMessage" class="text-gray-700 mb-6"></p>

    <button 
      onclick="closeAlertModal()" 
      class="bg-[#5f7550] text-white px-6 py-2 rounded"
    >
      OK
    </button>

  </div>

</div>
</body>
</html>
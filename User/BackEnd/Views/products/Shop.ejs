<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title || "Shop | PitchWear" %></title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg: "#fbfaf7",
            borderTone: "#d9d6c8",
            card: "#f3f1e7",
            primaryBtn: "#b36a8d",
            primaryBtnHover: "#9b5576",
            badgeDark: "#2f2f2f",
            badgeGreen: "#5f7550",
          }
        }
      }
    }
  </script>
</head>

<body class="bg-bg text-gray-800">


  <!-- HEADER -->
  <header class="w-full bg-bg border-b border-borderTone">
       <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex items-center justify-between">
      <a href="/home" class="font-bold text-lg tracking-wide">PitchWear</a>

      <nav class="hidden md:flex gap-10 text-sm text-gray-700">
        <a href="/home" class="hover:underline">Home</a>
        <a href="/shop" class="hover:underline font-medium">Shop</a>
        <a href="/about" class="hover:underline">About</a>
      </nav>
      
      <div class="flex items-center gap-5 text-lg">
        <a href="/wishlist" title="Wishlist" class="hover:opacity-70">♡</a>
        <a href="/cart" title="Cart" class="relative hover:opacity-70">
          🛒
          <% if (cartCount && cartCount > 0) { %>
            <span class="absolute -top-2 -right-2 bg-green-700 text-white text-[10px] px-1.5 py-[1px] rounded-full">
              <%= cartCount %>
            </span>
          <% } %>
        </a>
        <a href="/profile" title="Account" class="hover:opacity-70">👤</a>
      </div>
    </div>
  </header>

  <% if (message) { %>
  <div class="w-full flex justify-center mt-4">
    
    <div id="flashMessage"
         class="bg-green-600 text-white px-6 py-3 rounded-lg shadow text-sm font-medium">
      <%= message %>
    </div>

  </div>

  <script>
    setTimeout(() => {
      const el = document.getElementById("flashMessage");
      if (el) el.style.display = "none";
    }, 2000);
  </script>
<% } %>

<main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">

    <!-- HERO -->
    <section class="border border-borderTone bg-[#f7f6f0] px-6 py-10 text-center">
      <p class="text-xs tracking-widest text-gray-500 mb-2">Official Store</p>
<h2 class="text-2xl sm:text-3xl font-semibold mb-2">
        Match-Day Jerseys • Home & Away Kits
      </h2>
      <p class="text-sm text-gray-500">
        Authentic quality for the true fan. Wear your colors with pride.
      </p>
    </section>

    <!-- SEARCH + SORT -->
    <section class="mt-8 flex flex-col md:flex-row gap-4 md:items-center md:justify-between">

      <!-- Search -->
      <form action="/shop" method="GET" class="w-full md:w-[420px]" id="searchForm">
        <input type="hidden" name="sort" value="<%= sort || '' %>">

        <% (selectedTeams || []).forEach((t) => { %>
          <input type="hidden" name="teams" value="<%= t %>">
        <% }) %>
        <% (selectedTypes || []).forEach((t) => { %>
          <input type="hidden" name="types" value="<%= t %>">
        <% }) %>
        <% (selectedKits || []).forEach((k) => { %>
          <input type="hidden" name="kits" value="<%= k %>">
        <% }) %>
        

        <div class="bg-white border border-borderTone rounded-lg px-4 py-3 flex items-center gap-2">
          <span class="text-gray-400">🔍</span>

          <input
            type="text"
            name="search"
            id="searchInput"
            value="<%= search || '' %>"
            placeholder="Search by team or jersey name"
            class="w-full outline-none text-sm bg-transparent"
            autofocus
          />

          <% if (search && search.trim() !== "") { %>
            <a href="/shop" class="text-gray-400 hover:text-gray-700 font-semibold" title="Clear">✕</a>
          <% } %>
        </div>
      </form>

      <!-- Sort -->
      <form action="/shop" method="GET" class="flex items-center gap-3 justify-end">

  <input type="hidden" name="search" value="<%= search || '' %>">

  <!-- keep all your hidden filters here -->

  <div class="flex items-center gap-3">

    <span class="text-sm text-gray-600">Sort by</span>

    <div class="relative">
      <select
        name="sort"
        onchange="this.form.submit()"
        class="appearance-none bg-white border border-borderTone rounded-xl px-4 py-2 pr-10 text-sm shadow-sm hover:shadow-md hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-[#5f7550] transition"
      >

        <option value="priceLow" <%= sort === "priceLow" ? "selected" : "" %>>
          Price: Low → High
        </option>

        <option value="priceHigh" <%= sort === "priceHigh" ? "selected" : "" %>>
          Price: High → Low
        </option>

        <option value="az" <%= sort === "az" ? "selected" : "" %>>
          Name: A → Z
        </option>

        <option value="za" <%= sort === "za" ? "selected" : "" %>>
          Name: Z → A
        </option>

        <option value="latest" <%= sort === "latest" ? "selected" : "" %>>
          Latest
        </option>

      </select>

      <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
        ▼
      </span>
    </div>

  </div>

</form>
    </section>

    <!-- LAYOUT -->
<section class="mt-10 flex flex-col md:flex-row gap-10">

      <!-- FILTER SIDEBAR -->
      <aside class="w-64 hidden md:block">
        <h3 class="text-xl font-semibold mb-6">Filter By</h3>

        <form action="/shop" method="GET" class="space-y-5">
          <input type="hidden" name="search" value="<%= search || '' %>">
          <input type="hidden" name="sort" value="<%= sort || '' %>">

          <!-- Teams dropdown -->
          <div class="relative">
            <button type="button"
  onclick="toggleDropdown('teamsBox', this)"
  class="dropdownBtn w-full bg-white border border-borderTone rounded-xl px-4 py-3 flex justify-between items-center text-sm shadow-sm hover:shadow-md hover:border-[#cfcbb5] transition">

  <span class="font-medium flex items-center gap-2">
    ⚽ Teams
  </span>

  <svg class="arrow w-4 h-4 text-gray-400 transition-transform duration-200"
       xmlns="http://www.w3.org/2000/svg"
       fill="none"
       viewBox="0 0 24 24"
       stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M19 9l-7 7-7-7"/>
  </svg>

</button>
           <div id="teamsBox"
class="dropdown hidden mt-2 bg-white border border-borderTone rounded-xl p-4 space-y-3 shadow-xl animate-dropdown">
              <% (teams || []).forEach((t) => { %>
               <label class="filterOption flex items-center justify-between gap-3 text-sm px-3 py-2 rounded-lg cursor-pointer">

  <div class="flex items-center gap-3">
    <input
      type="checkbox"
      name="teams"
      value="<%= t %>"
      <%= (selectedTeams || []).includes(t) ? "checked" : "" %>
      class="accent-[#5f7550] w-4 h-4"
    />

    <span><%= t %></span>
  </div>

</label>
</label>
              <% }) %>
            </div>
          </div>

          <!-- Home/Away dropdown -->
          <div class="relative">
            <button type="button"
              onclick="toggleDropdown('typeBox')"
              class="w-full bg-white border border-borderTone rounded-xl px-4 py-3 flex justify-between items-center text-sm"
            >
              <span>Home/Away</span>
              <span class="text-gray-400">⌄</span>
            </button>

            <div id="typeBox" class="hidden mt-2 bg-white border border-borderTone rounded-xl p-4 space-y-3">
              <% (types || ["Home","Away"]).forEach((t) => { %>
                <label class="filterOption flex items-center justify-between gap-3 text-sm px-3 py-2 rounded-lg cursor-pointer">

  <div class="flex items-center gap-3">
    <input
      type="checkbox"
      name="types"
      value="<%= t %>"
      <%= (selectedTypes || []).includes(t) ? "checked" : "" %>
      class="accent-[#5f7550] w-4 h-4"
    />

    <span><%= t %></span>
  </div>

</label>
              <% }) %>
            </div>
          </div>

          <!-- Kit Type dropdown -->
          <div class="relative">
            <button type="button"
              onclick="toggleDropdown('kitBox')"
              class="w-full bg-white border border-borderTone rounded-xl px-4 py-3 flex justify-between items-center text-sm"
            >
              <span>Kit Type</span>
              <span class="text-gray-400">⌄</span>
            </button>

            <div id="kitBox" class="hidden mt-2 bg-white border border-borderTone rounded-xl p-4 space-y-3">
              <% (kits || ["Half Sleeve","Full Sleeve"]).forEach((k) => { %>
                <label class="flex items-center gap-3 text-sm">
                  <input
                    type="checkbox"
                    name="kits"
                    value="<%= k %>"
                    <%= (selectedKits || []).includes(k) ? "checked" : "" %>
                    class="w-4 h-4"
                  />
                  <span><%= k %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <!-- Price Range -->
          <div class="bg-white border border-borderTone rounded-xl p-4">
            <p class="text-sm font-medium mb-3">Price Range</p>
            <div class="flex gap-3">
              <input type="number" name="minPrice" placeholder="Min" value="<%= minPrice || '' %>" class="w-full border rounded-lg px-3 py-2 text-sm" />
              <input type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice || '' %>" class="w-full border rounded-lg px-3 py-2 text-sm" />
            </div>
          </div>

          <!-- Buttons -->
          <div class="pt-6 flex flex-col gap-3">
            <a href="/shop" class="bg-[#e9e7dc] text-gray-800 px-4 py-2 rounded-lg text-sm font-medium text-center hover:opacity-90">
              Clear All
            </a>

            <button type="submit" class="bg-primaryBtn hover:bg-primaryBtnHover text-white px-4 py-2 rounded-lg text-sm font-medium">
              Apply Filters
            </button>
          </div>
        </form>
      </aside>

      <!-- PRODUCTS -->
      <div class="flex-1">

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5 sm:gap-7">
          <% if (!products || products.length === 0) { %>
            <div class="col-span-4 text-center py-20 text-gray-400">
              No products found
            </div>
          <% } else { %>
            <% products.forEach((p) => { %>
              <a href="/product/<%= p.slug %>" class="block">
                <div class="bg-card rounded-2xl overflow-hidden border border-[#efeedd] hover:shadow-sm transition">
                  <div class="relative px-6 pt-6 pb-3 flex items-center justify-center">
                    <img src="<%= (p.images && p.images[0]) ? p.images[0] : '/images/no-image.png' %>" class="h-[130px] sm:h-[150px] object-contain"
              alt="<%= p.name %>" />
                  </div>
                  <div class="px-5 pb-5">
                    <h4 class="text-sm font-semibold leading-tight"><%= p.teamData?.name || p.name %></h4>
                    <p class="text-xs text-gray-500 mt-1"><%= p.kitType || "-" %></p>

                    <% if (p.totalStock === 0) { %>
                         <p class="text-sm font-medium mt-3 text-gray-400">
                        Out of Stock
                     </p>
                 <% } else { %>
                    <% if (p.discountPercent && p.discountPercent > 0) { %>

<div class="mt-3">

<span class="text-gray-400 line-through text-xs">
₹<%= Number(p.displayPrice).toFixed(2) %>
</span>

<p class="text-sm font-bold text-red-600">
₹<%= Number(p.offerPrice).toFixed(2) %>
</p>

<span class="text-green-600 text-xs font-semibold">
<%= p.discountPercent %>% OFF
</span>

</div>

<% } else { %>

<p class="text-sm font-semibold mt-3">
₹<%= Number(p.displayPrice).toFixed(2) %>
</p>

<% } %>
                <% } %>


                  </div>
                </div>
              </a>
            <% }) %>
          <% } %>
        </div>
        
          <% if (totalPages && totalPages > 1) { %>
              <div class="flex flex-wrap justify-center items-center gap-2 sm:gap-3 mt-10 text-sm">

            <% const baseUrl =
              `/shop?search=${encodeURIComponent(search || '')}` +
              `&sort=${encodeURIComponent(sort || '')}` +
              (selectedTeams || []).map(t => `&teams=${encodeURIComponent(t)}`).join("") +
              (selectedTypes || []).map(t => `&types=${encodeURIComponent(t)}`).join("") +
              (selectedKits || []).map(k => `&kits=${encodeURIComponent(k)}`).join("") +
              (minPrice ? `&minPrice=${encodeURIComponent(minPrice)}` : "") +
              (maxPrice ? `&maxPrice=${encodeURIComponent(maxPrice)}` : "");
            %>

            <% if (page > 1) { %>
              <a href="<%= baseUrl %>&page=<%= page - 1 %>"
                 class="w-9 h-9 rounded-lg bg-gray-200 flex items-center justify-center hover:bg-gray-300">
                ‹
              </a>
            <% } else { %>
              <span class="w-9 h-9 rounded-lg bg-gray-100 text-gray-400 flex items-center justify-center">‹</span>
            <% } %>

            <% for (let p = 1; p <= totalPages; p++) { %>
              <a href="<%= baseUrl %>&page=<%= p %>"
                 class="w-9 h-9 flex items-center justify-center rounded-lg border
                 <%= p === page
                   ? 'bg-[#5f7550] text-white border-[#5f7550]'
                   : 'bg-transparent border-transparent hover:bg-gray-200' %>">
                <%= p %>
              </a>
            <% } %>

            <% if (page < totalPages) { %>
              <a href="<%= baseUrl %>&page=<%= page + 1 %>"
                 class="w-9 h-9 rounded-lg bg-gray-200 flex items-center justify-center hover:bg-gray-300">
                ›
              </a>
            <% } else { %>
              <span class="w-9 h-9 rounded-lg bg-gray-100 text-gray-400 flex items-center justify-center">›</span>
            <% } %>

          </div>
        <% } %>
      </div>
  
    </section>
    



    <% if (error) { %>
  <div id="errorModal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">

    <div class="bg-white w-[90%] max-w-md rounded-2xl shadow-xl p-6 relative animate-fadeIn">

      <!-- Close Button -->
      <button
        onclick="closeErrorModal()"
        class="absolute top-3 right-4 text-gray-400 hover:text-gray-700 text-xl"
      >
        ✕
      </button>

      <!-- Icon -->
      <div class="flex justify-center mb-4">
        <div class="w-14 h-14 flex items-center justify-center rounded-full bg-red-100 text-red-600 text-2xl">
          !
        </div>
      </div>

      <!-- Title -->
      <h3 class="text-lg font-semibold text-center mb-2">
        Something went wrong
      </h3>

      <!-- Error Message -->
      <p class="text-sm text-gray-600 text-center">
        <%= error %>
      </p>

      <!-- Button -->
      <div class="mt-6 text-center">
        <button
          onclick="closeErrorModal()"
          class="bg-primaryBtn hover:bg-primaryBtnHover text-white px-6 py-2 rounded-lg text-sm"
        >
          Okay
        </button>
      </div>

    </div>
  </div>
<% } %>




  </main>

  <script>
    function toggleDropdown(id) {
      const el = document.getElementById(id);
      el.classList.toggle("hidden");
    }

    function handleSingleSelect(boxId, input) {
      const box = document.getElementById(boxId);

      box.querySelectorAll("input[type='checkbox']").forEach(cb => {
        if (cb !== input) cb.checked = false;
      });

      box.classList.add("hidden");
      input.closest("form").submit();
    }

    function debounce(fn, delay) {
      let timer;
      return function (...args) {
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, args), delay);
      };
    }

    document.addEventListener("DOMContentLoaded", () => {
  const searchInput = document.getElementById("searchInput");
  const searchForm = document.getElementById("searchForm");

  // ✅ NEW: keep cursor at end after reload
  if (searchInput) {
    const len = searchInput.value.length;
    searchInput.focus();
    searchInput.setSelectionRange(len, len);
  }

  if (searchInput && searchForm) {
    const debouncedSubmit = debounce(() => {
      searchForm.submit();
    }, 500);

    searchInput.addEventListener("input", debouncedSubmit);
  }

  document.querySelectorAll("#typeBox input").forEach(input => {
    input.addEventListener("change", () => {
      handleSingleSelect("typeBox", input);
    });
  });

  document.querySelectorAll("#kitBox input").forEach(input => {
    input.addEventListener("change", () => {
      handleSingleSelect("kitBox", input);
    });
  });
});
  

function closeErrorModal() {
  const modal = document.getElementById("errorModal");
  if (modal) {
    modal.remove();

    // Remove error from URL (clean URL after close)
    const url = new URL(window.location);
    url.searchParams.delete("error");
    window.history.replaceState({}, document.title, url.pathname + url.search);
  }
}


  </script>

</body>
</html>

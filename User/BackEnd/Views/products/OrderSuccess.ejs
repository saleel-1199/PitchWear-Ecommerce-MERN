<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Order Confirmed | PitchWear</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#f8f8f4] text-gray-800">

  <!-- ✅ SIMPLE HEADER -->
  <header class="bg-[#eff2c8] px-10 py-5 flex justify-between items-center shadow-sm">
    <a href="/" class="text-xl font-bold">PitchWear</a>

    <nav class="flex gap-6 text-sm">
      <a href="/" class="hover:underline">Home</a>
      <a href="/shop" class="hover:underline">Shop</a>
      <a href="/cart" class="hover:underline">
        Cart (<%= cartCount || 0 %>)
      </a>
    </nav>
  </header>

  <!-- ✅ PAGE CONTENT -->
  <main class="min-h-screen">

    <div class="max-w-6xl mx-auto px-6 py-10">

      <h1 class="text-gray-400 text-sm mb-4">Order Confirmed</h1>

      <!-- Banner -->
      <div class="rounded-xl overflow-hidden mb-8 shadow-sm">
        <img 
          src="/Images/Screenshot 2026-02-25 212555.png" 
          alt="Order Confirmed"
          class="w-full h-56 object-cover"
        />
      </div>

      <!-- Thank You -->
      <div class="mb-8">
        <h2 class="text-2xl font-semibold mb-2">
          Thank you for your order!
        </h2>
        <p class="text-gray-600 text-sm">
          Your order has been placed and will be processed shortly.
          You will receive tracking details once your order ships.
        </p>
      </div>

      <!-- Order Summary -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4">Order Summary</h3>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-sm">

          <div>
            <p class="text-gray-400">Order Number</p>
            <p class="font-medium"><%= order.orderId %></p>
          </div>

          <div>
            <p class="text-gray-400">Order Date</p>
            <p class="font-medium">
              <%= new Date(order.createdAt).toDateString() %>
            </p>
          </div>

          <div>
            <p class="text-gray-400">Payment Method</p>
            <p class="font-medium"><%= order.paymentMethod %></p>
          </div>

        </div>
      </div>

      <!-- Address -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 mb-10 text-sm">

        <div>
          <p class="text-gray-400 mb-1">Shipping Address</p>
          <p class="font-medium">
            <%= order.addressSnapshot.fullName %>
          </p>
          <p class="text-gray-600">
            <%= order.addressSnapshot.addressLine %><br>
            <%= order.addressSnapshot.city %>, 
            <%= order.addressSnapshot.state %> 
            <%= order.addressSnapshot.pincode %><br>
            <%= order.addressSnapshot.phone %>
          </p>
        </div>

        <div>
          <p class="text-gray-400 mb-1">Billing Address</p>
          <p class="font-medium">
            <%= order.addressSnapshot.fullName %>
          </p>
          <p class="text-gray-600">
            <%= order.addressSnapshot.addressLine %><br>
            <%= order.addressSnapshot.city %>, 
            <%= order.addressSnapshot.state %> 
            <%= order.addressSnapshot.pincode %><br>
            <%= order.addressSnapshot.phone %>
          </p>
        </div>

      </div>

      <!-- Items -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4">Items Ordered</h3>

        <div class="border rounded-xl overflow-hidden">

          <div class="grid grid-cols-3 bg-gray-50 px-4 py-3 text-sm font-medium">
            <span>Product</span>
            <span class="text-center">Quantity</span>
            <span class="text-right">Price</span>
          </div>

          <% order.items.forEach(item => { %>
            <div class="grid grid-cols-3 px-4 py-4 text-sm border-t">

              <div class="flex items-center gap-3">
                <img 
                  src="<%= item.product?.images?.[0] || '/images/placeholder.png' %>"
                  class="w-12 h-12 object-cover rounded-lg border"
                />
                <div>
                  <p class="font-medium">
                    <%= item.product?.name || "Product Removed" %>
                  </p>
                  <p class="text-gray-500 text-xs">
                    Size: <%= item.size %>
                  </p>
                </div>
              </div>

              <span class="text-center"><%= item.quantity %></span>

              <span class="text-right font-medium">
                ₹<%= item.price * item.quantity %>
              </span>

            </div>
          <% }) %>

        </div>
      </div>

      <!-- Total -->
      <div class="flex justify-end mb-10">
        <div class="text-right">
          <p class="text-gray-400 text-sm">Total Paid</p>
          <p class="text-xl font-semibold">
            ₹<%= order.finalTotal %>
          </p>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row justify-between gap-4">

        <a href="/orders/<%= order.orderId %>"
           class="px-6 py-3 rounded-lg bg-[#5f7550] text-white text-center hover:bg-[#4e6343]">
          Track My Order
        </a>

        <a href="/shop"
           class="px-6 py-3 rounded-lg bg-pink-500 text-white text-center hover:bg-pink-600">
          Continue Shopping
        </a>

      </div>

    </div>

  </main>

  <!-- ✅ SIMPLE FOOTER -->
  <footer class="bg-white border-t mt-10 py-6 text-center text-sm text-gray-500">
    © <%= new Date().getFullYear() %> PitchWear. All rights reserved.
  </footer>

</body>
</html>
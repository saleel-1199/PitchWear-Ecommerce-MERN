<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= product.name %> | PitchWear</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#fbfaf7] text-gray-800">

<!-- HEADER -->
<header class="border-b bg-[#fbfaf7]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex justify-between items-center">
    <a href="/home" class="font-bold text-lg">PitchWear</a>

    <nav class="hidden md:flex gap-8 text-sm">
      <a href="/home">Home</a>
      <a href="/shop" class="font-medium">Shop</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="flex gap-4 text-lg">
      <a href="/wishlist">♡</a>
      <a href="/cart">🛒</a>
      <a href="/account">👤</a>
    </div>
  </div>
</header>

<main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
<!-- BREADCRUMB -->
<p class="text-sm text-gray-500 mb-6">
  Home / Shop / <%= product.team?.name %>
</p>

<!-- PRODUCT SECTION -->
<section class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">

  <!-- LEFT: IMAGES -->
  <div>
    <div class="bg-[#f3f1e7] rounded-2xl p-4 sm:p-8 flex justify-center">
      <img
        src="<%= product.images[0] %>"
        class="h-[260px] sm:h-[320px] md:h-[380px] object-contain cursor-zoom-in"
        onclick="openImageZoom('<%= product.images[0] %>')"
      />
    </div>

    <div class="flex gap-3 mt-4 justify-center md:justify-start flex-wrap">
      <% product.images.forEach((img) => { %>
        <img
          src="<%= img %>"
          class="w-16 h-16 sm:w-20 sm:h-20 object-cover rounded-lg border cursor-pointer"
          onclick="openImageZoom('<%= img %>')"
        />
      <% }) %>
    </div>
  </div>

  <!-- RIGHT: DETAILS -->
  <div>

    <span class="inline-block bg-green-600 text-white text-xs px-3 py-1 rounded-full mb-3">
      <%= product.status %>
    </span>

    <h1 class="text-2xl sm:text-3xl font-semibold mb-2">
      <%= product.name %>
    </h1>

    <p class="text-sm text-gray-500 mb-4">
    <%= product.team?.name %> • <%= product.kitType %>• <%= product.type %>
    </p>

    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span id="priceText" class="text-2xl font-bold">
        ₹<%= product.displayPrice %>
      </span>
      <span class="text-green-700 text-sm">
        In Stock: <%= product.totalStock %>
      </span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm mb-6">
      <p><b>Sleeve:</b> <%= product.kitType %></p>
      <p><b>Kit Type:</b> <%= product.type %></p>
    </div>

   <% if (product.totalStock === 0) { %>
  <span class="text-red-600 font-semibold">
    Currently unavailable
  </span>
<% } else { %>
  <span class="text-green-600">
    In stock
  </span>
<% } %>
    <!-- SIZE -->
    <div class="mb-6">
      <p class="text-sm font-medium mb-2">Select Size</p>

      <div class="flex gap-3 flex-wrap">
        <% product.variants.forEach((v) => { %>
          <button
            type="button"
            data-price="<%= v.price %>"
            class="
              size-btn px-4 py-2 rounded-lg text-sm border transition
              <%= v.stock > 0
                ? 'bg-white shadow-md border-green-600 text-gray-800'
                : 'bg-gray-100 border-gray-300 text-gray-400 cursor-not-allowed'
              %>
            "
            <%= v.stock > 0 ? '' : 'disabled' %>
          >
            <%= v.size %>
          </button>
        <% }) %>
      </div>
    </div>

    <!-- QUANTITY -->
    <div class="mb-6">
  <p class="text-sm font-medium mb-2">Quantity</p>
  <div class="flex items-center gap-4 border rounded-lg w-fit px-4 py-2">
    <button type="button" onclick="changeQty(-1)">−</button>
    <span id="qtyDisplay">1</span>
    <button type="button" onclick="changeQty(1)">+</button>
  </div>
</div>

    <!-- ACTIONS -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
  
      <!-- ✅ ADD TO CART FORM -->
    <form action="/cart" method="POST" onsubmit="return validateCartForm()">

    <input type="hidden" name="productId" value="<%= product._id %>">

    <input type="hidden" name="size" id="selectedSize">

   <input type="hidden" name="quantity" id="selectedQty" value="1"> 

    <button
      type="submit"
      class="px-8 py-3 rounded-lg w-full sm:w-auto text-white
        <%= product.totalStock === 0
          ? 'bg-gray-400 cursor-not-allowed'
          : 'bg-[#5f7550] hover:bg-[#4e6343]' %>"
      <%= product.totalStock === 0 ? 'disabled' : '' %>
    >
      <%= product.totalStock === 0 ? 'Currently Unavailable' : 'Add to Cart' %>
    </button>

  </form>

  <form action="/wishlist" method="POST">
  <input type="hidden" name="productId" value="<%= product._id %>">

  <button
    type="submit"
    class="border px-5 py-3 rounded-lg w-full sm:w-auto hover:bg-gray-100 transition"
  >
    ♡ Wishlist
  </button>
</form>
</div>


    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center text-xs text-gray-600">
      <div>✔ Official Replica</div>
      <div>✔ Premium Fabric</div>
      <div>✔ Secure Payments</div>
      <div>✔ Easy Returns</div>
    </div>

    <div class="bg-white border rounded-lg p-4 mt-6 text-sm">
      <b>Care Instructions</b>
      <p class="text-gray-500 mt-1">
        Machine wash cold, do not iron print, tumble dry low.
      </p>
    </div>
      

    <!-- REVIEWS SECTION -->
<div class="mt-10 bg-white border rounded-2xl p-6">
  <h2 class="text-lg font-semibold mb-4">Customer Reviews</h2>

  <!-- Average Rating -->
  <div class="flex items-center gap-3 mb-6">
    <div class="flex text-yellow-500 text-lg">
      ★★★★☆
    </div>
    <span class="text-sm text-gray-600">4.2 out of 5 (23 reviews)</span>
  </div>

  <!-- Dummy Reviews -->
  <div class="space-y-5">
    <div class="border-b pb-4">
      <div class="flex items-center justify-between mb-1">
        <p class="font-medium text-sm">Rahul S.</p>
        <span class="text-yellow-500 text-sm">★★★★☆</span>
      </div>
      <p class="text-sm text-gray-600">
        Great quality jersey! Fabric feels premium and size fits perfectly.
      </p>
    </div>

    <div class="border-b pb-4">
      <div class="flex items-center justify-between mb-1">
        <p class="font-medium text-sm">Arjun K.</p>
        <span class="text-yellow-500 text-sm">★★★★★</span>
      </div>
      <p class="text-sm text-gray-600">
        Loved the design. Looks exactly like the original team kit.
      </p>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1">
        <p class="font-medium text-sm">Mohammed A.</p>
        <span class="text-yellow-500 text-sm">★★★☆☆</span>
      </div>
      <p class="text-sm text-gray-600">
        Good product overall, but delivery was slightly delayed.
      </p>
    </div>
  </div>
</div>

<!-- RELATED PRODUCTS -->
<div class="mt-12">
  <h2 class="text-xl font-semibold mb-6">
    Related Products
  </h2>
    
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5 sm:gap-7">
  <% if (!relatedProducts || relatedProducts.length === 0) { %>
    <div class="col-span-4 text-center py-20 text-gray-400">
      No related products found
    </div>
  <% } else { %>
    <% relatedProducts.forEach((p) => { %>
      <a href="/product/<%= p.slug %>" class="block">
        <div class="bg-card rounded-2xl overflow-hidden border border-[#efeedd] hover:shadow-sm transition">
          <div class="relative px-6 pt-6 pb-3 flex items-center justify-center">
            <img
              src="<%= (p.images && p.images[0]) ? p.images[0] : '/images/no-image.png' %>"
              class="h-[130px] sm:h-[150px] object-contain"
              alt="<%= p.name %>"
            />
          </div>
          <div class="px-5 pb-5">
            <h4 class="text-sm font-semibold leading-tight">
             <%= p.team?.name || p.name %>
            </h4>
            <p class="text-xs text-gray-500 mt-1">
              <%= p.kitType || "-" %>
            </p>
            <p class="text-sm font-semibold mt-3">
              ₹<%= Number(p.displayPrice || 0).toFixed(2) %>
            </p>
          </div>
        </div>
      </a>
    <% }) %>
  <% } %>
</div>
</div>

        
</div>
</div>

</section>

</main>

<!-- IMAGE ZOOM MODAL -->
<div
  id="imageZoomModal"
  class="fixed inset-0 bg-black/80 hidden z-50 flex items-center justify-center overflow-hidden"
>
  <button
    onclick="closeImageZoom()"
    class="absolute top-4 right-4 sm:top-6 sm:right-6 text-white text-3xl font-bold"
  >
    ×
  </button>

  <div class="absolute bottom-4 sm:bottom-6 flex gap-4">
    <button onclick="zoomOut()" class="bg-white px-4 py-2 rounded">−</button>
    <button onclick="zoomIn()" class="bg-white px-4 py-2 rounded">+</button>
  </div>

<img
  id="zoomImage"
  src=""
  class="max-h-[90vh] max-w-[90vw] object-contain cursor-grab select-none"
  draggable="false"
/>
</div>

<!-- EXISTING SIZE SCRIPT -->
<script>
  const priceText = document.getElementById("priceText");
  const sizeButtons = document.querySelectorAll(".size-btn");
  const selectedSizeInput = document.getElementById("selectedSize");

  sizeButtons.forEach(btn => {
    btn.addEventListener("click", () => {

      sizeButtons.forEach(b =>
        b.classList.remove("ring-2", "ring-green-600")
      );

      btn.classList.add("ring-2", "ring-green-600");

      // ✅ STORE SIZE
      selectedSizeInput.value = btn.innerText.trim();

      // ✅ UPDATE PRICE
      const price = btn.dataset.price;
      if (price && Number(price) > 0) {
        priceText.innerText = "₹" + price;
      }
    });
  });
</script>


  <!-- zoom -->


<script>
  const modal = document.getElementById("imageZoomModal");
  const img = document.getElementById("zoomImage");

  let scale = 1;
  let posX = 0;
  let posY = 0;
  let startX = 0;
  let startY = 0;
  let isDragging = false;

  const MIN_SCALE = 1;
  const MAX_SCALE = 4;

  function openImageZoom(src) {
    scale = 1;
    posX = 0;
    posY = 0;

    img.src = src;
    updateTransform();

    modal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeImageZoom() {
    modal.classList.add("hidden");
    document.body.style.overflow = "";
  }

  function updateTransform() {
    img.style.transform = `translate(${posX}px, ${posY}px) scale(${scale})`;
  }

  function zoomIn() {
    if (scale < MAX_SCALE) {
      scale += 0.25;
      updateTransform();
    }
  }

  function zoomOut() {
    if (scale > MIN_SCALE) {
      scale -= 0.25;
      if (scale < 1) scale = 1;

      if (scale === 1) {
        posX = 0;
        posY = 0;
      }

      updateTransform();
    }
  }

  /* ✅ Mouse Wheel Zoom (NO JUMP) */
  modal.addEventListener("wheel", (e) => {
    e.preventDefault();

    const delta = e.deltaY < 0 ? 1.15 : 0.85;
    const newScale = scale * delta;

    if (newScale < MIN_SCALE || newScale > MAX_SCALE) return;

    scale = newScale;
    updateTransform();
  });

  /* ✅ Drag / Pan */
  img.addEventListener("mousedown", (e) => {
    if (scale === 1) return;

    isDragging = true;
    startX = e.clientX - posX;
    startY = e.clientY - posY;

    img.classList.remove("cursor-grab");
    img.classList.add("cursor-grabbing");
  });

  document.addEventListener("mousemove", (e) => {
    if (!isDragging) return;

    posX = e.clientX - startX;
    posY = e.clientY - startY;

    updateTransform();
  });

  document.addEventListener("mouseup", () => {
    isDragging = false;

    img.classList.remove("cursor-grabbing");
    img.classList.add("cursor-grab");
  });

  /* ✅ ESC Close */
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeImageZoom();
  });

  /* ✅ Click Outside Close */
  modal.addEventListener("click", (e) => {
    if (e.target.id === "imageZoomModal") {
      closeImageZoom();
    }
  });
</script>



<script>
  function validateCartForm() {
    const size = document.getElementById("selectedSize").value;

    if (!size) {
      alert("Please select a size");
      return false;
    }

    return true;
  }
</script>



<script>
  let qty = 1;

  function changeQty(change) {
    qty += change;

    if (qty < 1) qty = 1;
    if (qty > 5) qty = 5;

    document.getElementById("qtyDisplay").innerText = qty;
    document.getElementById("selectedQty").value = qty;
  }
</script>



</body>
</html>

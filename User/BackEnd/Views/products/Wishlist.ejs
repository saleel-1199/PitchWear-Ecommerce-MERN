<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Wishlist | PitchWear</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#fbfaf7] text-gray-800">

<!-- ================= HEADER ================= -->
<header class="border-b bg-[#fbfaf7]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex justify-between items-center">
    <a href="/home" class="font-bold text-lg">PitchWear</a>

    <nav class="hidden md:flex gap-8 text-sm">
      <a href="/home">Home</a>
      <a href="/shop">Shop</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="flex gap-4 text-lg">
      <a href="/wishlist">♡</a>
      <a href="/cart">🛒</a>
      <a href="/account">👤</a>
    </div>
  </div>
</header>

<!-- ================= MAIN ================= -->
<main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

  <h1 class="text-2xl sm:text-3xl font-semibold mb-8">
    My Wishlist
  </h1>

  <% if (!wishlist.products.length) { %>

    <div class="text-center py-20 text-gray-400">
      <p class="text-lg">Your wishlist is empty</p>
      <a href="/shop" class="mt-4 inline-block text-sm text-green-700 underline">
        Continue Shopping
      </a>
    </div>

  <% } else { %>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">

    <% wishlist.products.forEach(p => { %>

      <div class="bg-white border rounded-2xl overflow-hidden hover:shadow-sm transition">

        <div class="px-6 pt-6 pb-3 flex items-center justify-center bg-[#f3f1e7]">
          <img
            src="<%= p.images[0] %>"
            class="h-[130px] sm:h-[150px] object-contain"
            alt="<%= p.name %>"
          />
        </div>

        <div class="px-5 pb-5">

          <h4 class="text-sm font-semibold leading-tight">
            <%= p.name %>
          </h4>

          <p class="text-xs text-gray-500 mt-1">
            <%= p.team?.name %>
          </p>

          <p class="text-sm font-semibold mt-3">
            ₹<%= p.variants?.[0]?.price || 0 %>
          </p>

          <div class="flex justify-between items-center mt-4">

            <!-- View Product -->
            <a href="/product/<%= p.slug %>"
               class="text-sm text-green-700 underline">
              View
            </a>

            <!-- Remove -->
            <form action="/wishlist/remove/<%= p._id %>" method="POST">
              <button class="text-sm text-red-500 hover:underline">
                Remove
              </button>
            </form>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

  <% } %>

</main>

</body>
</html>
<!-- 🔥 GLOBAL MODAL -->
<div id="customModal"
     class="fixed inset-0 bg-black bg-opacity-40 hidden items-center justify-center z-50">

  <div class="bg-white rounded-xl p-6 w-[350px] text-center shadow-lg">

    <p id="modalMessage" class="text-red-600 font-medium mb-4"></p>

    <button onclick="closeModal()"
      class="bg-black text-white px-4 py-2 rounded">
      OK
    </button>

  </div>
</div>

<script>
let redirectUrl = null; // store redirect

function showModal(message, redirect = null){
  document.getElementById("modalMessage").innerText = message;

  const modal = document.getElementById("customModal");

  modal.classList.remove("hidden"); // show modal
  modal.classList.add("flex");      // 🔥 FIX: enable centering

  redirectUrl = redirect; // store redirect
}

function closeModal(){
  const modal = document.getElementById("customModal");

  modal.classList.add("hidden");    // 🔥 FIX: hide modal
  modal.classList.remove("flex");   // remove flex

  // redirect AFTER user clicks OK
  if(redirectUrl){
    window.location.href = redirectUrl;
  }
}
</script>

</body>
</html>
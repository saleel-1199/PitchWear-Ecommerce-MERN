<script>

  let isProcessing = false;

document.getElementById("checkoutForm")
.addEventListener("submit", async function(e){
   
   if(isProcessing) return;   // 🚫 prevent double click
  isProcessing = true;


  const paymentMethod =
  document.querySelector('input[name="paymentMethod"]:checked').value;

  const address =
  document.querySelector('input[name="addressId"]:checked');

  if(!address){
    e.preventDefault();
    showModal("Please select address");
    return;
  }

  // 👉 HANDLE RAZORPAY
  if(paymentMethod === "Razorpay"){
    e.preventDefault();

    const res = await fetch("/checkout",{
      method:"POST",
      headers:{ "Content-Type":"application/json" },
      body:JSON.stringify({
        addressId: address.value,
        selectedPaymentMethod: paymentMethod
      })
    });

    const data = await res.json();

    if(!data.razorpay){
  showModal(data.message || "Something went wrong", data.redirect || null);
  return;
}

    const options = {
      key:data.key,
      amount:data.razorpayOrder.amount,
      currency:"INR",
      order_id:data.razorpayOrder.id,
      name: "PitchWear",
      description: "PitchWear Order Payment",


      modal: {
    ondismiss: function () {

      // call backend (don’t block)
      fetch("/payment-failed", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          orderId: data.razorpayOrder.id   // 🔥 Razorpay ID
        })
      }).catch(() => {});

      // redirect immediately
      window.location.href =
        "/orders/" + data.order._id + "?payment=failed";
    }
  },

      handler:async function(response){

        await fetch("/verify-payment",{
          method:"POST",
          headers:{ "Content-Type":"application/json" },
          body:JSON.stringify({
            orderId:response.razorpay_order_id,
            paymentId:response.razorpay_payment_id
          })
        });

        window.location.href="/order-success/"+data.order._id;
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();



    rzp.on("payment.failed", function (response) {

  isProcessing = false;

  // 🔥 CALL API BUT DON'T BLOCK REDIRECT
  fetch("/payment-failed", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      orderId: options.order_id
    })
  }).catch(() => {}); // ignore errors

  // 🔥 FORCE REDIRECT IMMEDIATELY
  window.location.href =
    "/orders/" + data.order._id + "?payment=failed";
});

  }

  // 👉 HANDLE WALLET (THIS IS YOUR FIX 🔥)
  else if(paymentMethod === "Wallet"){
    e.preventDefault();

    const res = await fetch("/checkout",{
      method:"POST",
      headers:{ "Content-Type":"application/json" },
      body:JSON.stringify({
        addressId: address.value,
        selectedPaymentMethod: paymentMethod
      })
    });

    const data = await res.json();

   if(!data.success){
  showModal(data.message, data.redirect || null);
  return;
}

    // success
    window.location.href="/order-success/"+data.orderId;
  }

  //cod

  else if(paymentMethod === "COD"){
  e.preventDefault();

  const res = await fetch("/checkout",{
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({
      addressId: address.value,
      selectedPaymentMethod: paymentMethod
    })
  });

  const data = await res.json();

  if(!data.success){
  showModal(data.message, data.redirect || null);
  return;
}
  window.location.href = "/order-success/" + data.orderId;
}
});

</script>





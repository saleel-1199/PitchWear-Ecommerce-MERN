<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Checkout | PitchWear</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>


<body class="bg-[#fbfaf7] text-gray-800">

<!-- ================= HEADER ================= -->
<header class="bg-white px-16 py-4 flex justify-between items-center">
  <h1 class="text-xl font-semibold">PitchWear</h1>

  <nav class="flex gap-8 text-sm">
    <a href="/home" class="hover:text-primary">Home</a>
    <a href="/shop" class="hover:text-primary">Shop</a>
    <a href="/about" class="hover:text-primary">About</a>
  </nav>

  <div class="flex items-center gap-4 text-lg">
    <a href="/wishlist" class="hover:scale-110 transition">♡</a>
    <a href="/cart" class="hover:scale-110 transition">🛒</a>
    <a href="/profile" class="hover:scale-110 transition">👤</a>
  </div>
</header>

<main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

  <!-- ✅ BREADCRUMB -->
  <p class="text-sm text-gray-500 mb-6">
    Shopping Cart / <span class="text-pink-600">Checkout</span>
  </p>

  <h1 class="text-2xl font-semibold mb-6">Checkout</h1>

  <!-- ✅ CART TABLE -->
  <div class="bg-white border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-600">
        <tr>
          <th class="text-left px-6 py-4">Product</th>
          <th class="text-left px-6 py-4">Price</th>
          <th class="text-left px-6 py-4">Quantity</th>
          <th class="text-left px-6 py-4">Total</th>
        </tr>
      </thead>

      <tbody class="divide-y">
        <% cart.items.forEach(item => { %>
          <tr>
            <td class="px-6 py-4 flex items-center gap-4">
              <img src="<%= item.product.images[0] %>"
                   class="w-12 h-12 object-cover rounded"/>

              <div>
                <p class="font-medium">
                  <%= item.product.team?.name %>
                </p>
                <p class="text-xs text-gray-500">
                  Size: <%= item.size %>
                </p>
              </div>
            </td>

            <td class="px-6 py-4">

<% if(item.originalPrice && item.originalPrice > item.price){ %>

<span class="text-gray-400 line-through text-xs">
₹<%= item.originalPrice.toFixed(2) %>
</span>

<p class="text-pink-600 font-semibold">
₹<%= item.price.toFixed(2) %>
</p>

<% } else { %>

<span class="text-pink-600 font-medium">
₹<%= item.price.toFixed(2) %>
</span>

<% } %>

</td>

            <td class="px-6 py-4">
              <%= item.quantity %>
            </td>

            <td class="px-6 py-4 font-semibold">
              ₹<%= item.subtotal.toFixed(2) %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- ✅ ADDRESS SELECTION -->
  <div class="mt-10">
    <h2 class="text-lg font-semibold mb-4">
      Select Delivery Address
    </h2>

<form id="checkoutForm" class="space-y-3">
  
  
<input type="hidden" name="selectedPaymentMethod" id="paymentMethodInput">


      <% if (!addresses.length) { %>
        <p class="text-sm text-gray-500">
          No saved addresses
        </p>
      <% } %>

      <% addresses.forEach(addr => { %>
        <label class="flex items-start gap-3 border rounded-lg p-4 cursor-pointer hover:bg-gray-50">
          <input
            type="radio"
            name="addressId"
            value="<%= addr._id %>"
            required
            class="mt-1"
            <%= addr.is_default ? "checked" : "" %>
          />

          <div class="text-sm">
            <p class="font-medium"><%= addr.full_name %></p>
            <p class="text-gray-500">
              <%= addr.address_line1 %>, <%= addr.city %>,
              <%= addr.state %> - <%= addr.pin_code %>
            </p>
            <p class="text-gray-400 text-xs">
              📞 <%= addr.phone_no %>
            </p>
          </div>
        </label>
      <% }) %>



      <button
  type="button"
  onclick="openAddressModal()"
  class="text-sm text-pink-600 hover:underline"
>
  + Add New Address
</button>


      <!-- ✅ SUMMARY -->
      <div class="mt-10 bg-white border rounded-xl p-6">
        <h3 class="font-semibold mb-4">Cart Price Summary</h3>
           

   


<!-- AVAILABLE COUPONS -->
<div class="mt-4">
  <p class="text-sm font-medium mb-2">Available Coupons</p>

  <% if(coupons && coupons.length){ %>
    <div class="space-y-2">

      <% coupons.forEach(c => { %>
        <div class="flex justify-between items-center border p-3 rounded">

          <div class="text-sm">
            <p class="font-semibold text-green-600">
              <%= c.code %>
            </p>
            <p class="text-xs text-gray-500">
              <%= c.discountPercent %>% OFF • Min ₹<%= c.minPurchase %>
            </p>
          </div>

          <% if(appliedCoupon && appliedCoupon.code === c.code){ %>

  <button
    type="button"
    class="bg-green-500 text-white px-3 py-1 rounded text-xs cursor-not-allowed">
    Applied
  </button>

<% } else { %>

  <button
    type="button"
    onclick="applyCouponFromList('<%= c.code %>')"
    class="bg-black text-white px-3 py-1 rounded text-xs">
    Apply
  </button>

<% } %>

        </div>
      <% }) %>

    </div>
  <% } else { %>
    <p class="text-xs text-gray-400">No coupons available</p>
  <% } %>
</div>


        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span>Total</span>
            <span>₹<%= cart.subtotal.toFixed(2) %></span>
          </div>

          <div class="flex justify-between">
            <span>Delivery Fee</span>
            <span>₹<%= cart.deliveryFee.toFixed(2) %></span>
          </div>

          <div class="flex justify-between">
            <span>Discount</span>
            <span class="text-red-500">
              -₹<%= cart.discount.toFixed(2) %>
            </span>
          </div>

          <div class="flex justify-between">
            <span>GST & Taxes</span>
            <span>₹<%= cart.tax.toFixed(2) %></span>
          </div>

          <div class="border-t pt-3 flex justify-between font-semibold">
            <span>Final Amount</span>
            <span>₹<%= cart.finalTotal.toFixed(2) %></span>
          </div>
        </div>



        <!-- PAYMENT METHOD -->
<div class="mt-6">
  <h3 class="font-medium mb-3">Payment Method</h3>

  <label class="flex items-center gap-2 text-sm">
    <input type="radio" name="paymentMethod" value="COD" checked>
    Cash on Delivery
  </label>

  <label class="flex items-center gap-2 text-sm mt-2">
    <input type="radio" name="paymentMethod" value="Razorpay">
    Razorpay (UPI / Card / Netbanking)
  </label>

  <label class="flex items-center gap-2 text-sm mt-2">
    <input type="radio" name="paymentMethod" value="Wallet">
    Wallet Payment
  </label>
  
</div>


<button
  type="submit"
  class="mt-6 w-full bg-[#b36a8d] hover:bg-[#9b5576]
         text-white py-3 rounded-lg font-medium">
  Continue to Payment
</button>
      </div>

    </form>
  </div>

</main>


<!-- ADD ADDRESS MODAL -->
<div id="addressModal"
     class="fixed inset-0 bg-black bg-opacity-40 hidden
            items-center justify-center z-50">

  <div class="bg-white rounded-xl w-[500px] p-6 relative">

    <button
      onclick="closeAddressModal()"
      class="absolute right-4 top-3 text-gray-500 text-lg">
      ✕
    </button>

    <h2 class="text-lg font-semibold mb-4">Add New Address</h2>

    <form id="checkoutAddressForm" class="space-y-4">

      <input name="full_name" placeholder="Full Name"
             class="w-full border px-3 py-2 rounded" required>

      <input id="phone_no" name="phone_no"
             placeholder="Phone Number"
             class="w-full border px-3 py-2 rounded"
             required>

      <input id="alt_phone_no" name="alt_phone_no"
             placeholder="Alternative Phone"
             class="w-full border px-3 py-2 rounded">

      <input name="address_line1"
             placeholder="Address Line"
             class="w-full border px-3 py-2 rounded"
             required>

      <div class="grid grid-cols-2 gap-3">

        <input name="city"
               placeholder="City"
               class="border px-3 py-2 rounded"
               required>

        <input name="state"
               placeholder="State"
               class="border px-3 py-2 rounded"
               required>

      </div>

      <input id="pin_code"
             name="pin_code"
             placeholder="Pincode"
             class="w-full border px-3 py-2 rounded"
             required>

      <select name="type"
              class="w-full border px-3 py-2 rounded"
              required>
        <option value="">Select Type</option>
        <option value="Home">Home</option>
        <option value="Work">Work</option>
      </select>

      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="is_default">
        Set as default
      </label>

      <button
        type="submit"
        class="w-full bg-pink-600 text-white py-2 rounded">
        Save Address
      </button>

    </form>

  </div>
</div>

<script>
function openAddressModal() {
  const modal = document.getElementById("addressModal");
  modal.classList.remove("hidden");
  modal.classList.add("flex");
}

function closeAddressModal() {
  const modal = document.getElementById("addressModal");
  modal.classList.add("hidden");
  modal.classList.remove("flex");
}

async function applyCouponFromList(code){

  const subtotal = <%= cart.subtotal %>

  const res = await fetch("/checkout/apply-coupon",{
    method:"POST",
    headers:{
      "Content-Type":"application/json"
    },
    body:JSON.stringify({
      code,
      subtotal
    })
  })

  const data = await res.json()

  if(data.success){
    location.reload()
  }else{
    showModal(data.message)
  }
}


</script>

<script>
document
  .getElementById("checkoutAddressForm")
  .addEventListener("submit", async (e) => {

    e.preventDefault();

    const form = e.target;

    const data = {
      full_name: form.full_name.value,
      phone_no: form.phone_no.value,
      alt_phone_no: form.alt_phone_no.value,
      address_line1: form.address_line1.value,
      city: form.city.value,
      state: form.state.value,
      pin_code: form.pin_code.value,
      type: form.type.value,
      is_default: form.is_default.checked
    };

    try {

      const res = await fetch("/address", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-Requested-With": "XMLHttpRequest"
        },
        body: JSON.stringify(data)
      });

      if (res.ok) {

        closeAddressModal();

        location.reload();

      } else {
       showModal ("Failed to save address");
      }

    } catch (err) {
      console.error(err);
      showModal("Something went wrong");
    }

});
</script>

<script>
function onlyDigits(input, maxLen) {
  input.addEventListener("input", () => {
    input.value = input.value.replace(/\D/g, "").slice(0, maxLen);
  });
}

onlyDigits(document.getElementById("phone_no"), 10);
onlyDigits(document.getElementById("alt_phone_no"), 10);
onlyDigits(document.getElementById("pin_code"), 6);
</script>





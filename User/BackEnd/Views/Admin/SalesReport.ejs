<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sales Report | PitchWear</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#f8f8f4] text-gray-800">

<!-- HEADER -->
<header class="bg-[#eff2c8] px-10 py-5 flex items-center justify-between">

<div class="flex items-center gap-10">
<h1 class="font-bold text-lg">Pitchwear</h1>
<p class="text-sm font-semibold">Admin Dashboard</p>
</div>

<div class="w-11 h-11 rounded-xl bg-white flex items-center justify-center border">
👤
</div>

</header>

<main class="flex px-10 py-10 gap-10">

<!-- SIDEBAR -->

<aside class="w-64">

<p class="text-sm text-gray-500 mb-5">Pitchwear Admin</p>

<nav class="space-y-2 text-sm">

<a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
🏠 Dashboard
</a>

<a href="/admin/products" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
👕 Product Management
</a>

<a href="/admin/teams" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
⚽ Manage Teams
</a>

<a href="/admin/orders" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
📦 Order Management
</a>

<a href="/admin/users" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
👥 User Management
</a>

<a href="/admin/coupons" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
🧾 Coupons
</a>

<a href="/admin/offers" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
🎁 Offers
</a>

<a href="/admin/sales-report" class="flex items-center gap-3 px-4 py-2 rounded-lg bg-white font-medium">
📊 Sales Report
</a>

<a href="/admin/logout" class="flex items-center gap-3 px-4 py-2 rounded-lg text-red-600 font-medium mt-6">
⛔ Logout
</a>

</nav>

</aside>



<!-- CONTENT AREA -->

<section class="flex-1">


<!-- BREADCRUMB -->

<nav class="mb-6 text-sm text-gray-500">
Dashboard / <span class="text-gray-700 font-semibold">Sales Report</span>
</nav>



<!-- PAGE HEADER -->

<div class="flex justify-between items-center mb-6">

<h2 class="text-3xl font-bold">Sales Report</h2>

<div class="flex gap-3">

<a href="/sales-report/pdf"
class="bg-red-500 hover:bg-red-600 text-white px-5 py-2 rounded-lg shadow">

Download PDF

</a>

<a href="/sales-report/excel"
class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg shadow">

Download Excel

</a>

</div>

</div>



<!-- FILTER PANEL -->

<form method="GET"
class="flex flex-wrap items-end gap-4 mb-8 bg-white border rounded-xl px-6 py-5 shadow-sm">

<!-- FILTER TYPE -->

<div class="flex flex-col">

<label class="text-sm text-gray-500 mb-1">
Report Type
</label>

<div class="relative">

<select
name="filter"
class="appearance-none bg-white border border-gray-300 text-gray-700
px-4 py-2 pr-10 rounded-lg shadow-sm
focus:outline-none focus:ring-2 focus:ring-[#cdd47b] focus:border-[#cdd47b]
hover:border-gray-400 transition">

<option value="">Select Filter</option>

<option value="daily" <%= filter === "daily" ? "selected" : "" %>>
Daily
</option>

<option value="weekly" <%= filter === "weekly" ? "selected" : "" %>>
Weekly
</option>

<option value="yearly" <%= filter === "yearly" ? "selected" : "" %>>
Yearly
</option>

</select>

<!-- Dropdown Arrow -->

<div class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-gray-500">
▼
</div>

</div>

</div>


<!-- START DATE -->

<div class="flex flex-col">

<label class="text-sm text-gray-500 mb-1">
Start Date
</label>

<input
type="date"
name="startDate"
value="<%= startDate || '' %>"
class="border border-gray-300 px-4 py-2 rounded-lg focus:ring-2 focus:ring-[#cdd47b]">

</div>



<!-- END DATE -->

<div class="flex flex-col">

<label class="text-sm text-gray-500 mb-1">
End Date
</label>

<input
type="date"
name="endDate"
value="<%= endDate || '' %>"
class="border border-gray-300 px-4 py-2 rounded-lg focus:ring-2 focus:ring-[#cdd47b]">

</div>



<!-- APPLY BUTTON -->

<button
class="bg-[#cdd47b] hover:bg-[#bfc66d] text-gray-900 px-6 py-2 rounded-lg text-sm font-semibold">

Apply

</button>



<!-- CLEAR BUTTON -->

<a
href="/admin/sales-report"
class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-5 py-2 rounded-lg text-sm font-semibold">

Clear

</a>

</form>



<!-- SUMMARY CARDS -->

<div class="grid grid-cols-4 gap-6 mb-8">

<div class="bg-white border rounded-xl p-6">

<p class="text-sm text-gray-500">
Total Orders
</p>

<p class="text-2xl font-bold">
<%= reports.length %>
</p>

</div>


<div class="bg-white border rounded-xl p-6">

<p class="text-sm text-gray-500">
Total Sales
</p>

<p class="text-2xl font-bold">
₹<%= reports.reduce((sum,r)=>sum+r.subtotal,0) %>
</p>

</div>


<div class="bg-white border rounded-xl p-6">

<p class="text-sm text-gray-500">
Total Discounts
</p>

<p class="text-2xl font-bold">
₹<%= reports.reduce((sum,r)=>sum+r.discount,0) %>
</p>

</div>


<div class="bg-white border rounded-xl p-6">

<p class="text-sm text-gray-500">
Net Revenue
</p>

<p class="text-2xl font-bold">
₹<%= reports.reduce((sum,r)=>sum+r.finalTotal,0) %>
</p>

</div>

</div>



<!-- SALES TABLE -->

<div class="bg-white border rounded-xl overflow-hidden">

<table class="w-full text-sm">

<thead class="bg-gray-50 text-gray-600">

<tr>

<th class="text-left px-6 py-4">Order ID</th>
<th class="text-left px-6 py-4">Date</th>
<th class="text-left px-6 py-4">Orders</th>
<th class="text-left px-6 py-4">Amount</th>
<th class="text-left px-6 py-4">Discount</th>
<th class="text-left px-6 py-4">Final</th>

</tr>

</thead>

<tbody>

<% if(reports.length === 0){ %>

<tr>

<td colspan="6" class="text-center py-16 text-gray-400">
No sales found
</td>

</tr>

<% } %>



<% reports.forEach(r=>{ %>

<tr class="border-t hover:bg-gray-50">

<td class="px-6 py-4 font-medium">
<%= r.orderId %>
</td>

<td class="px-6 py-4">
<%= new Date(r.createdAt).toDateString() %>
</td>

<td class="px-6 py-4">
1
</td>

<td class="px-6 py-4">
₹<%= r.subtotal %>
</td>

<td class="px-6 py-4 text-red-500">
₹<%= r.discount %>
</td>

<td class="px-6 py-4 font-semibold text-green-700">
₹<%= r.finalTotal %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</section>

</main>

</body>
</html>
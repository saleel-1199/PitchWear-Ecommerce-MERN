<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Team</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#f8f8f4] text-gray-800">

<!-- HEADER -->
<header class="bg-[#eff2c8] px-10 py-5 flex items-center justify-between">
  <div class="flex items-center gap-10">
    <h1 class="font-bold text-lg">Pitchwear</h1>
    <p class="text-sm font-semibold">Admin Dashboard</p>
  </div>
  
</header>

<main class="flex px-10 py-10 gap-10">

  <!-- SIDEBAR -->
      <%- include("partials/sidebar") %>

  <!-- CONTENT -->
  <section class="flex-1 max-w-3xl">

    <!-- BREADCRUMB -->
    <nav class="mb-6 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-gray-500">

        <li>
          <a href="/admin/dashboard"
             class="hover:text-gray-700 font-medium">
            Dashboard
          </a>
        </li>

        <li>/</li>

        <li>
          <a href="/admin/teams?page=<%= page %>&search=<%= search %>"
             class="hover:text-gray-700 font-medium">
            Teams
          </a>
        </li>

        <li>/</li>

        <li class="text-gray-700 font-semibold">
          Edit Team
        </li>

      </ol>
    </nav>

    <!-- TITLE -->
    <h2 class="text-3xl font-bold mb-8">Edit Team</h2>

    <!-- EDIT FORM CARD -->
    <div class="bg-white border rounded-xl p-6">

      <form
        action="/admin/teams/<%= team._id %>/edit?page=<%= page %>&search=<%= search %>"
        method="POST"
        autocomplete="off"
        class="space-y-6">

        <!-- TEAM NAME -->
        <div>
          <label class="block text-sm font-medium mb-1">
            Team Name
          </label>

            <!-- ✅ ERROR HERE -->
  <% if (error) { %>
    <p class="text-red-500 text-sm mb-2">
      <%= error %>
    </p>
  <% } %>

          <input
            type="text"
            name="name"
            value="<%= team.name %>"
            required
            class="w-full border rounded-lg px-4 py-2
                   focus:outline-none
                   focus:ring-2
                   focus:ring-green-500"
          />
        </div>

        <!-- ACTION BUTTONS -->
        <div class="flex justify-end gap-3">
          <a href="/admin/teams?page=<%= page %>&search=<%= search %>"
             class="px-5 py-2 border rounded-lg">
            Cancel
          </a>

          <button
            type="submit"
            class="bg-green-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-green-700">
            Update Team
          </button>
        </div>

      </form>

    </div>

  </section>
</main>

</body>
</html>

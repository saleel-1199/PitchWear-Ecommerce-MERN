<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Team Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#f8f8f4] text-gray-800">

<header class="bg-[#eff2c8] px-10 py-5 flex items-center justify-between">
  <div class="flex items-center gap-10">
    <h1 class="font-bold text-lg">Pitchwear</h1>
    <p class="text-sm font-semibold">Admin Dashboard</p>
  </div>
  <div class="w-11 h-11 rounded-xl bg-white flex items-center justify-center border">
    👤
  </div>
</header>

<main class="flex px-10 py-10 gap-10">

  <!-- SIDEBAR -->
  <aside class="w-64">
    <p class="text-sm text-gray-500 mb-5">Pitchwear Admin</p>

    <nav class="space-y-2 text-sm">
      <a href="/admin/dashboard"
         class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
        🏠 Dashboard
      </a>

      <a href="/admin/products"
         class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white">
        👕 Product Management
      </a>

      <a href="/admin/teams"
         class="flex items-center gap-3 px-4 py-2 rounded-lg bg-white font-medium">
        ⚽ Team Management
      </a>

      <a href="/admin/logout"
         class="flex items-center gap-3 px-4 py-2 rounded-lg text-red-600 font-medium mt-6">
        ⛔ Logout
      </a>
    </nav>
  </aside>

  <!-- CONTENT -->
  <section class="flex-1">

    <% const safeSearch = search || ""; %>
    <% const safePage = currentPage || 1; %>

    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-gray-500">
        <li>
          <a href="/admin/dashboard" class="hover:text-gray-700 font-medium">
            Dashboard
          </a>
        </li>
        <li>/</li>
        <li class="text-gray-700 font-semibold">Teams</li>
      </ol>
    </nav>

    <!-- TITLE + SEARCH + ADD -->
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-3xl font-bold">Team Management</h2>

      <button onclick="openModal()"
              class="bg-green-600 text-white px-5 py-2 rounded-lg font-semibold">
        + Add Team
      </button>
    </div>

    <!-- SEARCH BAR -->
    <form method="GET" action="/admin/teams" class="mb-6 flex gap-3">
      <input
        type="text"
        id="searchInput"
        name="search"
        value="<%= safeSearch %>"
        placeholder="Search teams..."
        class="w-64 border rounded-lg px-4 py-2"
        autocomplete="off"
        autofocus
      />

      <button
        type="button"
        class="bg-green-600 text-white px-5 py-2 rounded-lg font-semibold">
        Search
      </button>
    </form>

    <!-- TEAMS TABLE -->
    <div class="bg-white border rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-100 text-gray-600">
          <tr>
            <th class="px-6 py-4 text-left">Team Name</th>
            <th class="px-6 py-4 text-center">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% if (teams.length === 0) { %>
            <tr>
              <td colspan="2" class="text-center py-10 text-gray-400">
                No teams found
              </td>
            </tr>
          <% } %>

          <% teams.forEach(team => { %>
            <tr class="border-t">
              <td class="px-6 py-4 font-medium">
                <%= team.name %>
              </td>

              <td class="px-6 py-4 text-center space-x-3">
                <a
                  href="/admin/teams/<%= team._id %>/edit?page=<%= safePage %>&search=<%= safeSearch %>"
                  class="inline-flex items-center gap-2
                         px-4 py-2 text-sm font-semibold
                         text-red-600 border border-red-600 rounded-lg
                         hover:bg-red-600 hover:text-white transition">
                  ✏ Edit
                </a>

                <form
  action="/admin/teams/<%= team._id %>?_method=DELETE&page=<%= safePage %>&search=<%= safeSearch %>"
  method="POST"
  class="inline"
>
  <button
    class="bg-red-600 text-white px-6 py-2 rounded-lg text-xs font-semibold">
    Delete
  </button>
</form>

              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
      <div class="flex justify-center gap-2 mt-8">

        <% if (safePage > 1) { %>
          <a
            href="/admin/teams?page=<%= safePage - 1 %>&search=<%= safeSearch %>"
            class="px-4 py-2 border rounded-lg">
            Prev
          </a>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
          <a
            href="/admin/teams?page=<%= i %>&search=<%= safeSearch %>"
            class="px-4 py-2 border rounded-lg
            <%= i === safePage ? 'bg-green-600 text-white' : '' %>">
            <%= i %>
          </a>
        <% } %>

        <% if (safePage < totalPages) { %>
          <a
            href="/admin/teams?page=<%= safePage + 1 %>&search=<%= safeSearch %>"
            class="px-4 py-2 border rounded-lg">
            Next
          </a>
        <% } %>

      </div>
    <% } %>

  </section>
</main>

<!-- ADD TEAM MODAL (UNCHANGED) -->
<div id="teamModal"
     class="fixed inset-0 bg-black/40
            <%= showModal ? 'flex' : 'hidden' %>
            items-center justify-center">
  <div class="bg-white p-6 rounded-xl w-[400px]">
    <h3 class="text-lg font-semibold mb-4">Add Team</h3>

    <div id="teamError"
      class="mb-3 text-sm text-red-600 bg-red-50 px-3 py-2 rounded
             <%= error ? '' : 'hidden' %>">
      <%= error || '' %>
    </div>

    <form id="addTeamForm" action="/admin/teams/add" method="POST" class="space-y-4" novalidate>
      <input
        type="text"
        name="name"
        required
        placeholder="Enter team name"
        class="w-full border rounded px-3 py-2"
      />

      <div class="flex justify-end gap-3">
        <button type="button" onclick="closeModal()" class="border px-4 py-2 rounded">
          Cancel
        </button>
        <button class="bg-green-600 text-white px-4 py-2 rounded">
          Save
        </button>
      </div>
    </form>
  </div>
</div>


<!-- error modal -->


<% if (error) { %>
<div id="errorModal"
     class="fixed inset-0 bg-black/40 flex items-center justify-center z-50">

  <div class="bg-white rounded-xl shadow-xl w-[380px] p-6">

    <h3 class="text-lg font-semibold text-red-600 mb-3">
      ⚠ Action Failed
    </h3>

    <p class="text-sm text-gray-600 mb-6">
      <%= error %>
    </p>

    <div class="flex justify-end">
      <button onclick="closeErrorModal()"
              class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded-lg text-sm font-semibold">
        OK
      </button>
    </div>

  </div>
</div>
<% } %>

<script>
  function openModal() {
    teamModal.classList.remove("hidden");
    teamModal.classList.add("flex");
  }

  function closeModal() {
    teamModal.classList.add("hidden");
    teamModal.classList.remove("flex");
  }
</script>

<script>
  const teamForm = document.getElementById("addTeamForm");
  const teamError = document.getElementById("teamError");
  const teamNameInput = teamForm.querySelector("input[name='name']");

  teamForm.addEventListener("submit", (e) => {
    if (!teamNameInput.value.trim()) {
      e.preventDefault();
      teamError.textContent = "Team name cannot be empty.";
      teamError.classList.remove("hidden");
    }
  });

  teamNameInput.addEventListener("input", () => {
    teamError.classList.add("hidden");
    teamError.textContent = "";
  });
</script>

<script>
  const searchInput = document.getElementById("searchInput");

  let debounceTimer;

  searchInput.addEventListener("input", function () {
    clearTimeout(debounceTimer);

    debounceTimer = setTimeout(() => {
      const value = searchInput.value.trim();

      // Always reset to page 1 when searching
      const url = new URL(window.location.href);
      url.searchParams.set("search", value);
      url.searchParams.set("page", 1);

      window.location.href = url.toString();
    }, 500); // 500ms debounce delay
  });
</script>

<!-- ✅ ERROR MODAL SCRIPT -->
<script> 
  function closeErrorModal() {
    const modal = document.getElementById("errorModal");
    if (modal) modal.style.display = "none";
  }
</script>

<script>
  document.addEventListener("click", (e) => {
    const modal = document.getElementById("errorModal");
    if (!modal) return;

    if (e.target === modal) {
      closeErrorModal();
    }
  });
</script>



</body>
</html>

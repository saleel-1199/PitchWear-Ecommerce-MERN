<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Enter OTP</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const inputs = document.querySelectorAll(".otp-input");

      console.log("OTP inputs found:", inputs.length); // should be 6

      inputs.forEach((input, index) => {
        input.addEventListener("input", () => {
          if (input.value && index < inputs.length - 1) {
            inputs[index + 1].focus();
          }
        });

        input.addEventListener("keydown", (e) => {
          if (e.key === "Backspace" && !input.value && index > 0) {
            inputs[index - 1].focus();
          }
        });
        input.addEventListener("paste", (e) => {
    e.preventDefault();

    const pasteData = e.clipboardData.getData("text").trim();

    if (!/^\d+$/.test(pasteData)) return;

    pasteData.split("").forEach((digit, i) => {
      if (inputs[i]) {
        inputs[i].value = digit;
      }
    });

    inputs[Math.min(pasteData.length - 1, inputs.length - 1)].focus();
  });

      });

      // ✅ RESEND TIMER LOGIC (1 minute)
      const resendBtn = document.getElementById("resendBtn");
const timerText = document.getElementById("timerText");

// get stored time or default
let timeLeft = localStorage.getItem("otpTimer");

if (!timeLeft) {
  timeLeft = 60;
} else {
  timeLeft = parseInt(timeLeft);
}

function formatTime(seconds) {
  const m = String(Math.floor(seconds / 60)).padStart(2, "0");
  const s = String(seconds % 60).padStart(2, "0");
  return `${m} : ${s}`;
}

function updateTimer() {
  if (timeLeft > 0) {

    timerText.innerText =
      `Resend available in ${formatTime(timeLeft)}`;

    timeLeft--;

    // ✅ persist timer
    localStorage.setItem("otpTimer", timeLeft);

  } else {

    timerText.innerText = "You can resend OTP now";

    resendBtn.disabled = false;

    resendBtn.classList.remove(
      "opacity-40",
      "cursor-not-allowed"
    );

    resendBtn.classList.add("opacity-100");

    localStorage.removeItem("otpTimer");

    clearInterval(interval);
  }
}

updateTimer();
const interval = setInterval(updateTimer, 1000);
    });


function validateOtp() {
  const inputs = document.querySelectorAll(".otp-input");
  const errorBox = document.getElementById("otpError");

  let isValid = true;

  inputs.forEach(input => {
    if (!input.value.trim()) {
      isValid = false;
    }
  });

  if (!isValid) {
    errorBox.innerText = "Please enter complete OTP";
    errorBox.classList.remove("hidden");
    return false;
  }

  return true;
}

  </script>
</head>

<body class="bg-[#faf9f7] min-h-screen flex items-center justify-center">

  <div class="w-full max-w-xl bg-white px-16 py-14">

    <a href="/signup" class="flex items-center gap-2 mb-8 cursor-pointer">
      <div class="border border-black p-1">
        ←
      </div>
      <span class="text-sm font-medium">Back</span>
    </a>

    <!-- Heading -->
    <h1 class="text-3xl font-bold mb-2">Enter<br>OTP</h1>
    <p class="text-gray-500 mb-10">
      Enter the 6-digit code sent to your email
    </p>

    <!-- ✅ MESSAGE PART -->
   <% if (error) { %>
  <div class="mb-6 text-center text-red-600 text-sm font-medium">
    <%= error %>
  </div>
<% } %>

<p id="otpError" class="text-red-500 text-sm mb-4 hidden text-center"></p>

    <!-- ✅ OTP Verify Form (ONLY this form) -->
    <form action="/VerifyOtp" method="POST" onsubmit="return validateOtp()">
      <input type="hidden" name="email" value="<%= email %>">
      <div class="flex gap-4 mb-6">
        <% for(let i = 0; i < 6; i++) { %>
          <input
            type="text"
            maxlength="1"
            name="otp[]"
            class="otp-input w-12 h-14 text-center border border-gray-400 text-lg focus:outline-none focus:border-black"
          />
        <% } %>
      </div>

      <!-- Verify Button -->
      <button
        type="submit"
        class="w-full bg-[#d6c87a] text-white py-4 font-medium flex items-center justify-center gap-2 hover:opacity-90 transition"
      >
        Verify →
      </button>
    </form>

    <!-- ✅ Timer & Resend (OUTSIDE the verify form) -->
    <div class="flex justify-between items-center text-sm text-gray-500 mt-6">
      
      <span id="timerText">Resend available in 01 : 00</span>

      <form action="/resend-otp" method="POST">
          <input type="hidden" name="email" value="<%= email %>">

        <button
          type="submit"
          id="resendBtn"
          disabled
          class="font-medium text-black hover:underline opacity-40 cursor-not-allowed transition"
        >
          Resend Code
        </button>
      </form>
    </div>

    <!-- Footer -->
    <div class="text-center mt-8 text-sm text-gray-500">
      Having trouble?
      <a href="#" class="text-black font-medium hover:underline">
        Contact Support
      </a>
    </div>

  </div>

  <script>
<% if (otpResent) { %>
  localStorage.removeItem("otpTimer");
<% } %>
</script>

</body>
</html>
 
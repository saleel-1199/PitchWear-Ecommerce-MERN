<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>PitchWear</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#6b8e23',
            dark: '#111111',
            light: '#f9fafb'
          }
        }
      }
    }
  </script>
</head>

<body class="bg-light text-gray-800">

<!-- ================= NAVBAR ================= -->
<header class="w-full bg-bg border-b border-borderTone">
       <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex items-center justify-between">
      <a href="/home" class="font-bold text-lg tracking-wide">PitchWear</a>

      <nav class="hidden md:flex gap-10 text-sm text-gray-700">
        <a href="/home" class="hover:underline">Home</a>
        <a href="/shop" class="hover:underline font-medium">Shop</a>
        <a href="/about" class="hover:underline">About</a>
      </nav>
      
        <a href="/profile" title="Account" class="hover:opacity-70">👤</a>
      </div>
    </div>
  </header>

<!-- ================= HERO ================= -->
<section class="relative h-[600px]">

  <div class="absolute inset-0 bg-[url('/Images/photo-1616124619460-ff4ed8f4683c.jpg')] bg-cover bg-center"></div>
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 flex flex-col justify-center h-full px-20 text-white">

    <h1 class="text-6xl font-bold leading-tight mb-6">
      WEAR THE GAME <br> OWN THE STYLE
    </h1>

    <p class="text-gray-300 mb-8 max-w-lg">
      Discover premium football jerseys from top clubs around the world.
    </p>

    <div class="flex gap-4">

      <a href="/shop"
         class="border px-8 py-3 rounded-full hover:bg-white hover:text-black transition">
        Explore
      </a>
    </div>

  </div>

</section>

<!-- ================= FEATURES ================= -->
<section class="px-20 py-16 bg-white grid grid-cols-4 gap-8 text-center">

  <div>
    <h3 class="font-semibold mb-2">Free Shipping</h3>
    <p class="text-sm text-gray-500">On orders above ₹999</p>
  </div>

  <div>
    <h3 class="font-semibold mb-2">Easy Returns</h3>
    <p class="text-sm text-gray-500">7-day return policy</p>
  </div>

  <div>
    <h3 class="font-semibold mb-2">Secure Payment</h3>
    <p class="text-sm text-gray-500">100% safe checkout</p>
  </div>

  <div>
    <h3 class="font-semibold mb-2">Premium Quality</h3>
    <p class="text-sm text-gray-500">Authentic jerseys</p>
  </div>

</section>



<!-- ================= PRODUCTS ================= -->
<section class="bg-white px-20 py-16">

  <div class="flex justify-between items-center mb-10">
    <h2 class="text-3xl font-bold">Leatest Jerseys</h2>
    <a href="/shop" class="text-primary font-medium">View All →</a>
  </div>

  <div class="grid grid-cols-4 gap-8">

    <% products.forEach(product => { %>

      <a href="/product/<%= product.slug %>" 
   class="group block border rounded-xl overflow-hidden hover:shadow-xl transition cursor-pointer">

        <div class="relative overflow-hidden">
         <img src="<%= product.images[0] %>"
            class="h-64 w-full object-contain bg-white p-4 group-hover:scale-110 transition duration-300">

        </div>

        <div class="p-4 text-center">

          <h4 class="font-medium"><%= product.name %></h4>

          <p class="text-primary mt-1 font-semibold">
            ₹<%= product.variants[0]?.price || 0 %>
          </p>

        </div>

      </a>

    <% }) %>

  </div>

</section>

<!-- ================= BANNER ================= -->
<section class="bg-primary text-white py-20 text-center">

  <h2 class="text-4xl font-bold mb-4">Exclusive Offer</h2>
  <p class="mb-6">Get Upto 20% off on selected jerseys</p>

  <a href="/shop"
     class="bg-white text-black px-8 py-3 rounded-full font-medium">
    Shop Now
  </a>

</section>

<!-- ================= FOOTER ================= -->
<footer class="bg-dark text-gray-300 px-20 py-12">

  <div class="grid grid-cols-4 gap-10 text-sm">

    <div>
      <h4 class="text-white mb-3 font-semibold">PitchWear</h4>
      <p>Premium football jerseys for fans.</p>
    </div>

    <div>
      <h4 class="text-white mb-3 font-semibold">Shop</h4>
      <p>All Products</p>
      <p>New Arrivals</p>
    </div>

    <div>
      <h4 class="text-white mb-3 font-semibold">Support</h4>
      <p>Contact</p>
      <p>Returns</p>
    </div>

    <div>
      <h4 class="text-white mb-3 font-semibold">Follow</h4>
      <p>Instagram</p>
      <p>Twitter</p>
    </div>

  </div>

</footer>

<!-- ================= SCRIPT ================= -->
<script>
async function addToCart(productId){
  const res = await fetch("/cart/add", {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({ productId })
  });

  const data = await res.json();

  if(data.success){
    alert("Added to cart");
  }
}
</script>

</body>
</html>
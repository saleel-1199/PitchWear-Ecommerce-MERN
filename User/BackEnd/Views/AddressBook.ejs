<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Address Book | PitchWear</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#7da77b',
            bgLight: '#faf9f6'
          }
        }
      }
    }
  </script>
</head>

<body class="bg-bgLight text-gray-800">

<!-- HEADER -->
<header class="bg-[#f5f6df] px-16 py-4 flex justify-between items-center">
  <h1 class="text-lg font-semibold">PitchWear</h1>

  <nav class="flex items-center gap-10 text-sm">
    <a href="/Home" class="hover:text-primary">Home</a>
    <a href="/shop" class="hover:text-primary">Shop</a>
    <a href="#" class="hover:text-primary">About</a>
    <a href="#" class="hover:text-primary">Contact</a>

    <% if (user.profileImage) { %>
      <img
        src="<%= user.profileImage %>"
        class="w-8 h-8 rounded-full object-cover border"
      />
    <% } else { %>
      <div
        class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-semibold"
        style="background-color:#1e3a8a"
      >
        <%= user.fullName.charAt(0).toUpperCase() %>
      </div>
    <% } %>
  </nav>
</header>


<!-- MAIN LAYOUT -->
<main class="px-16 py-14 flex gap-16">

<!-- SIDEBAR -->
<aside class="w-64">

  <div class="bg-white rounded-lg p-4 mb-6">
    <p class="text-sm font-medium">My Account</p>
    <p class="text-xs text-gray-500"><%= user.fullName %></p>
  </div>

  <ul class="space-y-4 text-sm">

    <li>
      <a href="/orders" class="hover:text-primary">My Orders</a>
    </li>

    <li>
      <a href="/address" class="text-primary font-medium">Address Book</a>
    </li>

    <li>
      <a href="/wallet" class="hover:text-primary">Wallet</a>
    </li>

  </ul>

  <div class="mt-10 text-sm space-y-4">
    <p>About Us</p>
    <a href="/logout" class="text-red-500">← Logout</a>
  </div>

</aside>


<!-- CONTENT -->
<section class="flex-1 bg-white rounded-xl p-10">

<h2 class="text-2xl font-semibold mb-8">Address Book</h2>

<% if (addresses.length === 0) { %>

<div class="mt-10">
  <a href="/address/new"
     class="bg-green-600 text-white px-6 py-3 rounded-md inline-block">
     Add New Address
  </a>
</div>

<% } else { %>

<% addresses.forEach(address => { %>

<div class="relative bg-gray-100 rounded-xl overflow-hidden mb-8">

<div class="p-6">
<p class="font-semibold"><%= address.full_name %></p>

<p class="text-sm text-gray-700"><%= address.phone_no %></p>

<p class="text-sm text-gray-700">
<%= address.address_line1 %>, 
<%= address.city %>, 
<%= address.state %> 
<%= address.pin_code %>
</p>

<p class="text-sm text-gray-500"><%= address.type %></p>
</div>


<% if (address.is_default) { %>
<span class="absolute top-5 right-5 bg-pink-400 text-white text-xs px-4 py-2 rounded-full">
Default
</span>
<% } %>


<div class="p-6 flex gap-4">

<a href="/address/edit/<%= address._id %>"
   class="bg-yellow-400 px-6 py-2 rounded-md text-sm">
Edit
</a>

<button onclick="openDeleteModal('<%= address._id %>')"
        class="bg-red-500 text-white px-6 py-2 rounded-md text-sm">
Delete
</button>

</div>

</div>

<% }) %>

<a href="/address/new"
   class="bg-green-600 text-white px-6 py-3 rounded-md inline-block">
Add New Address
</a>

<% } %>

</section>

</main>


<!-- DELETE MODAL -->
<div id="deleteModal"
     class="hidden fixed inset-0 bg-black/40 flex items-center justify-center">

<div class="bg-white w-[450px] rounded-xl p-8 text-center">

<h2 class="font-bold text-lg">Confirm Deletion</h2>

<p class="text-sm text-gray-500 mt-2">
Are you sure you want to delete this address?
</p>

<div class="flex justify-center gap-4 mt-6">

<a id="confirmDeleteBtn"
   class="bg-pink-600 text-white px-6 py-2 rounded-md text-sm">
Yes, Delete
</a>

<button onclick="closeDeleteModal()"
        class="bg-gray-200 px-6 py-2 rounded-md text-sm">
Cancel
</button>

</div>

</div>

</div>


<script>
function openDeleteModal(id) {
  document.getElementById("deleteModal").classList.remove("hidden");
  document.getElementById("confirmDeleteBtn").href = "/address/delete/" + id;
}

function closeDeleteModal() {
  document.getElementById("deleteModal").classList.add("hidden");
}
</script>

</body>
</html>